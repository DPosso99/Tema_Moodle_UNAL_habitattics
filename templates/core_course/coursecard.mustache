{{!
    @template course_course/coursecard

    This template renders the a card for the course cards.

    Example context (json):
    {
        "courses": [
            {
                "name": "Assignment due 1",
                "viewurl": "https://moodlesite/course/view.php?id=2",
                "courseimage": "https://moodlesite/pluginfile/123/course/overviewfiles/123.jpg",
                "fullname": "course 3",
                "hasprogress": true,
                "progress": 10,
                "visible": true
            }
        ]
    }
}}
<div class="moove-course-card-target {{^visible}}dimmed{{/visible}}" role="listitem"
    data-region="course-content"
    data-course-id="{{{id}}}">

    <img class="moove-card-background-image" src="{{{courseimage}}}" alt="">

    <div class="moove-card-overlay"></div>

    <div class="moove-card-hover-overlay">
        <a href="{{viewurl}}" class="moove-card-btn-hover">
            Ingresar <i class="fa fa-arrow-right"></i>
        </a>
    </div>

    <div class="moove-card-content">
        <div class="moove-card-top">
            {{#coursecategory}}<span class="moove-card-level">{{{coursecategory}}}</span>{{/coursecategory}}
            <h5 class="moove-card-title">{{fullname}}</h5>
        </div>
        <a href="{{viewurl}}" class="moove-card-button">
            <span>Ingresar</span>
            <i class="fa fa-arrow-right"></i>
        </a>
    </div>
</div>
