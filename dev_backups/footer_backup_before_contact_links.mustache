{{!
    @template theme_moove/footer

    Page footer.

    Example context (json):
    {
        "output": {
            "page_doc_link": "Help and documentation",
            "supportemail": "<a href=\"#\">Contact site support</a>",
            "has_popover_links": true,
            "services_support": "Services and support",
            "login_info": "You are logged in as cute kitten",
            "moodle_release": "90210"
        }
    }
}}

<footer id="page-footer">
    <div class="moove-container-fluid footer-columns">
        <div class="row">
            <div class="col-md-4 column-left">
                {{# output.supportemail }}<div class="supportemail">{{{ output.supportemail }}}</div>{{/ output.supportemail }}
                {{{ output.login_info }}}
            </div>
            <div class="col-md-4 column-center">
                <img src="/theme/moove/pix/logo.svg"
                alt="Logo de la u"
                class="d-block mx-auto"
                style="max-width: 80%; height: auto;">

                
            </div>
            <div class="col-md-4 column-right">
              <div class="text-center text-light p-3">
                <h5 class="mb-2">Escuela del Hábitat</h5>
                <p class="mb-1">Profesor encargado:<br><strong>Juan Carlos Ceballos Guerra</strong></p>
                <p class="mb-0">Universidad Nacional de Colombia</p>
              </div>
            </div>

        </div>
    </div>
    <div class="footer-content-debugging footer-dark bg-dark text-light">
        <div class="moove-container-fluid footer-dark-inner">
            {{{ output.debug_footer_html }}}
        </div>
    </div>
    <div data-region="footer-container-popover">
        {{#output.has_communication_links}}<button onclick="window.open('{{output.communication_url}}', '_blank', 'noreferrer')" class="btn btn-icon bg-primary text-white icon-no-margin btn-footer-communication" aria-label="{{#str}}communicationroomlink, course{{/str}}">{{#pix}}t/messages-o, core{{/pix}}</button>{{/output.has_communication_links}}
        <button class="btn btn-icon bg-secondary icon-no-margin btn-footer-popover" data-action="footer-popover" aria-label="{{#str}}showfooter, theme_boost{{/str}}">{{#pix}}e/question, core{{/pix}}</button>
    </div>
    <div class="footer-content-popover container" data-region="footer-content-popover">
        {{# output.has_popover_links }}
            <div class="footer-section p-3 border-bottom">
                {{# output.page_doc_link }}<div>{{{ output.page_doc_link }}}</div>{{/ output.page_doc_link }}
                {{# output.services_support_link }}<div>{{{ output.services_support_link }}}</div>{{/ output.services_support_link }}
            </div>
        {{/ output.has_popover_links }}
        
    </div>
    
    
</footer>

{{! --- INICIO Script Modo Oscuro (Navbar) y Estado Activo Link --- }}
<script>
(function() {
    // --- Funciones Modo Oscuro ---
    function toggleDarkModeNavbar() {
        document.body.classList.toggle('darkmode');
        localStorage.setItem('themeMode', document.body.classList.contains('darkmode') ? 'dark' : 'light');
    }
    function applyInitialDarkMode() {
        const savedMode = localStorage.getItem('themeMode');
        if (savedMode === 'dark') document.body.classList.add('darkmode');
        else document.body.classList.remove('darkmode');
    }
    // --- Fin Funciones Modo Oscuro ---

    // --- INICIO: Función para Estado Activo "Cursos Disponibles" ---
    function handleNavbarActiveLink() {
        const coursesLink = document.getElementById('nav-courses-available');
        const basePath = (typeof M !== 'undefined' && M.cfg && M.cfg.wwwroot)
                       ? M.cfg.wwwroot.replace(/^https?:\/\/[^\/]+/, '')
                       : '';
        const targetPath = basePath + '/course/index.php';

        if (coursesLink && window.location.pathname.startsWith(targetPath)) {
             coursesLink.classList.add('active');
        } else if (coursesLink) {
             coursesLink.classList.remove('active');
        }
    }
    // --- FIN: Función Estado Activo ---

    // Ejecutar al cargar el DOM
    document.addEventListener('DOMContentLoaded', function() {
        applyInitialDarkMode();
        handleNavbarActiveLink();

        // Listener para botón modo oscuro de la NAVBAR
        const navbarToggleBtn = document.getElementById('darkmode-toggle');
        if (navbarToggleBtn) {
            navbarToggleBtn.addEventListener('click', function(event) {
                event.preventDefault();
                toggleDarkModeNavbar();
            });
        }
        // El botón de frontpage (#darkmodeBtn) se maneja en frontpage.php
    });
})();
</script>
{{! --- FIN Scripts --- }}

{{{ output.standard_end_of_body_html }}}

